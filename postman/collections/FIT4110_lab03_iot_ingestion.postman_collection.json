{
  "info": {
    "name": "FIT4110 Lab03 - Access Gate Contract Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Service is access-gate', function () { pm.expect(pm.response.json().service).to.eql('access-gate'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /api/v1/gates/{gateId}/command - OPEN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/gates/GATE-A-01/command",
            "body": {
              "mode": "raw",
              "raw": "{\"command\":\"OPEN\",\"requestedBy\":\"ADMIN-01\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Gate opened successfully', function () { pm.expect(pm.response.json().gateStatus).to.eql('OPENED'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/access/verify - Swipe IN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/access/verify",
            "body": {
              "mode": "raw",
              "raw": "{\"cardId\":\"CARD123\",\"gateId\":\"GATE-01\",\"direction\":\"IN\",\"timestamp\":\"2026-06-02T10:00:00Z\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Decision is present', function () { pm.expect(pm.response.json()).to.have.property('decision'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /api/v1/access/verify - Missing Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/v1/access/verify",
            "body": {
              "mode": "raw",
              "raw": "{\"cardId\":\"CARD123\",\"gateId\":\"GATE-01\",\"direction\":\"IN\",\"timestamp\":\"2026-06-02T10:00:00Z\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('env') !== 'mock') {",
                  "  pm.test('Missing token returns 401', function () { pm.expect(pm.response.code).to.eql(401); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "POST /api/v1/gates/{gateId}/command - Invalid Enum",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": "{{baseUrl}}/api/v1/gates/GATE-A-01/command",
            "body": {
              "mode": "raw",
              "raw": "{\"command\":\"NHAY_QUA_CONG\",\"requestedBy\":\"ADMIN-01\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid command returns 400', function () { pm.expect([400, 422]).to.include(pm.response.code); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/gates/{gateId}/command - Hardware Failure Conflict",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=409" }
            ],
            "url": "{{baseUrl}}/api/v1/gates/GATE-A-01/command",
            "body": {
              "mode": "raw",
              "raw": "{\"command\":\"OPEN\",\"requestedBy\":\"ADMIN-01\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Conflict 409 is returned as negotiated', function () { pm.expect(pm.response.code).to.eql(409); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "POST /api/v1/gates/{gateId}/command - EMERGENCY_OPEN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/gates/GATE-ALL/command",
            "body": {
              "mode": "raw",
              "raw": "{\"command\":\"EMERGENCY_OPEN\",\"requestedBy\":\"FIRE-ALARM\",\"reason\":\"Fire detected\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Emergency command accepted', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Smoke Test Core Policy Mock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{coreBusinessMockUrl}}/api/v1/access/verify",
            "body": {
              "mode": "raw",
              "raw": "{\"cardId\":\"CARD123\",\"gateId\":\"GATE-01\",\"direction\":\"IN\",\"timestamp\":\"2026-06-02T10:00:00Z\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Can call Core Business mock successfully', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "POST /api/v1/access/verify - SLA < 300ms",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/access/verify",
            "body": {
              "mode": "raw",
              "raw": "{\"cardId\":\"CARD123\",\"gateId\":\"GATE-01\",\"direction\":\"IN\",\"timestamp\":\"2026-06-02T10:00:00Z\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('env') === 'local') {",
                  "  pm.test('Verify access resolves under 300ms (Negotiated timeout)', function () { pm.expect(pm.response.responseTime).to.be.below(300); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}