        {
          "name": "POST /command - missing token rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/gates/GATE-A-01/command",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "gates",
                "GATE-A-01",
                "command"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"command\": \"OPEN\",\n  \"requestedBy\": \"CORE-SYS-01\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Auth test thật: không dùng Prefer header. Prism không enforce auth thật nên skip trên mock."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "  pm.test('Error body follows ProblemDetails', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json.status).to.be.within(400, 599);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
